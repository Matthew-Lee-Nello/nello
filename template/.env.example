# nello-claw .env - all keys in one place
# After editing, run: bash scripts/sync-env-to-configs.sh

# ============================================================
# Messaging channel - pick ONE: telegram or whatsapp
# ============================================================
# Which channel your assistant texts you on. Switch any time with /connect-telegram
# or /connect-whatsapp.
MESSAGING_CHANNEL=telegram

# --- Telegram (used when MESSAGING_CHANNEL=telegram) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=
# Your Telegram chat ID - captured automatically the first time you message the bot.
ALLOWED_CHAT_ID=

# --- WhatsApp (used when MESSAGING_CHANNEL=whatsapp) ---
# Your own number in international digits, no + or spaces (e.g. 61412345678). You
# don't set this by hand: run /connect-whatsapp, scan the QR, and it's captured for
# you. Your "Message Yourself" chat becomes your assistant. Unofficial WhatsApp Web
# protocol - small flag risk on the number.
WHATSAPP_OWNER_NUMBER=

# ============================================================
# Voice (optional)
# ============================================================

# Groq (free tier, speech-to-text via Whisper)
GROQ_API_KEY=

# ============================================================
# Composio Tool Router - the connection layer (Gmail, Calendar, Drive, Slack, Notion + 1000 apps)
# ============================================================
# One-click OAuth per app, no Google Cloud setup, no delete/trash (blocked server-side).
# You only set COMPOSIO_API_KEY; the installer mints COMPOSIO_MCP_URL from it at bootstrap.
#   COMPOSIO_API_KEY  - your Composio project API key (the only Composio secret here)
#   COMPOSIO_MCP_URL  - this install's durable Tool Router URL (auto-filled by bootstrap)
#   COMPOSIO_USER_ID  - this install's unique id (defaults to your Google email)
COMPOSIO_API_KEY=
COMPOSIO_MCP_URL=
COMPOSIO_USER_ID=
GOOGLE_USER_EMAIL=

# OpenAI (optional, for GPT-4o-mini note extraction)
OPENAI_API_KEY=

# Tavily (research skill)
TAVILY_API_KEY=

# Exa (research skill)
EXA_API_KEY=

# Firecrawl (research skill + scraping)
FIRECRAWL_API_KEY=

# Apify (optional, web scraping marketplace)
APIFY_TOKEN=

# n8n (optional, only if you use n8n)
N8N_API_URL=
N8N_API_KEY=

# ============================================================
# System
# ============================================================

NODE_ENV=production
LOG_LEVEL=info
